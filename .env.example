# CloudShift Configuration Example
# Copy this file to .env and customize.

# Deployment: demo (Gemini) vs client (Ollama)
CLOUDSHIFT_DEPLOYMENT_MODE=client

# Auth: api_key | searce_id (demo) | password (client)
CLOUDSHIFT_AUTH_MODE=api_key
# When auth_mode=api_key: set key below. When empty, auth is disabled.
CLOUDSHIFT_API_KEY=
# When auth_mode=searce_id (demo): Searce ID issuer/audience (optional)
# CLOUDSHIFT_SEARCE_ID_ISSUER=
# CLOUDSHIFT_SEARCE_ID_AUDIENCE=
# When auth_mode=password (client): path to JSON {"username": "bcrypt_or_sha256_hash"}
# Use bcrypt for new users: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# CLOUDSHIFT_USERS_FILE=data/users.json
# CLOUDSHIFT_JWT_SECRET=change-me-in-production
# CLOUDSHIFT_JWT_TTL_SECONDS=86400

# CORS
# Comma-separated list of allowed origins
CLOUDSHIFT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,vscode-webview://*

# Path validation: directories allowed for scanning (include . and data so snippet projects are scannable)
CLOUDSHIFT_ALLOWED_SCAN_PATHS=.,data

# Directories
CLOUDSHIFT_PATTERNS_DIR=patterns
CLOUDSHIFT_DATA_DIR=data
CLOUDSHIFT_DB_PATH=data/cloudshift.db

# LLM - Client (Ollama, e.g. Qwen 2)
CLOUDSHIFT_LLM_ENABLED=false
CLOUDSHIFT_OLLAMA_BASE_URL=http://localhost:11434
CLOUDSHIFT_OLLAMA_MODEL=qwen2:latest
CLOUDSHIFT_OLLAMA_TIMEOUT=120.0

# LLM - Demo (Gemini). See docs/gemini-api-key.md for getting and securing a key.
# CLOUDSHIFT_GEMINI_API_KEY=
# CLOUDSHIFT_GEMINI_MODEL=gemini-1.5-flash
# CLOUDSHIFT_GEMINI_TIMEOUT=120.0

# Logging
CLOUDSHIFT_LOG_LEVEL=INFO
CLOUDSHIFT_DEBUG=false
