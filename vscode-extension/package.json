{
  "name": "cloudshift",
  "displayName": "CloudShift",
  "description": "Detect and refactor cloud infrastructure constructs across providers",
  "version": "0.1.0",
  "publisher": "cloudshift",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asmeyatsky/cloudshift.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:terraform",
    "workspaceContains:*.tf"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cloudshift.scanProject",
        "title": "CloudShift: Scan Project"
      },
      {
        "command": "cloudshift.refactorSelectionAwsToGcp",
        "title": "CloudShift: Refactor Selection (AWS → GCP)"
      },
      {
        "command": "cloudshift.refactorSelectionAzureToGcp",
        "title": "CloudShift: Refactor Selection (Azure → GCP)"
      },
      {
        "command": "cloudshift.refactorFileAwsToGcp",
        "title": "CloudShift: Refactor File (AWS → GCP)"
      },
      {
        "command": "cloudshift.refactorFileAzureToGcp",
        "title": "CloudShift: Refactor File (Azure → GCP)"
      },
      {
        "command": "cloudshift.validate",
        "title": "CloudShift: Validate Transformations"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cloudshift.refactorSelectionAwsToGcp",
          "when": "editorHasSelection",
          "group": "cloudshift@1"
        },
        {
          "command": "cloudshift.refactorSelectionAzureToGcp",
          "when": "editorHasSelection",
          "group": "cloudshift@1"
        },
        {
          "command": "cloudshift.refactorFileAwsToGcp",
          "group": "cloudshift@2"
        },
        {
          "command": "cloudshift.refactorFileAzureToGcp",
          "group": "cloudshift@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cloudshift-explorer",
          "title": "CloudShift",
          "icon": "$(cloud)"
        }
      ]
    },
    "views": {
      "cloudshift-explorer": [
        {
          "id": "manifestTree",
          "name": "Manifest"
        },
        {
          "id": "validationTree",
          "name": "Validation"
        }
      ]
    },
    "configuration": {
      "title": "CloudShift",
      "properties": {
        "cloudshift.serverUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the CloudShift FastAPI backend server"
        },
        "cloudshift.autoScan": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan files on open and save"
        },
        "cloudshift.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Static API key (X-API-Key / X-Searce-ID). Use when backend uses api_key or searce_id auth."
        },
        "cloudshift.bearerToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "JWT Bearer token (Authorization: Bearer). Use when backend uses password auth; get token after logging in on the Web UI (see README)."
        },
        "cloudshift.iapClientId": {
          "type": "string",
          "default": "",
          "markdownDescription": "IAP OAuth 2.0 Client ID (required for IAP). Get it from the IAP login redirect or your backend's IAP config."
        },
        "cloudshift.iapCredentialsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to a **service account** JSON key file for IAP. Required for IAP: create a SA, add it to IAP access, download key, set this path. Or set GOOGLE_APPLICATION_CREDENTIALS."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.24.0",
    "typescript": "~5.7.0"
  }
}
